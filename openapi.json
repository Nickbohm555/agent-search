{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "InternalDataLoadRequest": {
        "properties": {
          "documents": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/InternalDocumentInput"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Documents"
          },
          "source_type": {
            "default": "inline",
            "enum": [
              "inline",
              "wiki"
            ],
            "title": "Source Type",
            "type": "string"
          },
          "wiki": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/WikiLoadInput"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "title": "InternalDataLoadRequest",
        "type": "object"
      },
      "InternalDataLoadResponse": {
        "properties": {
          "chunks_created": {
            "title": "Chunks Created",
            "type": "integer"
          },
          "documents_loaded": {
            "title": "Documents Loaded",
            "type": "integer"
          },
          "source_type": {
            "title": "Source Type",
            "type": "string"
          },
          "status": {
            "const": "success",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "source_type",
          "documents_loaded",
          "chunks_created"
        ],
        "title": "InternalDataLoadResponse",
        "type": "object"
      },
      "InternalDocumentInput": {
        "properties": {
          "content": {
            "minLength": 1,
            "title": "Content",
            "type": "string"
          },
          "source_ref": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Ref"
          },
          "source_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Url"
          },
          "title": {
            "minLength": 1,
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "title",
          "content"
        ],
        "title": "InternalDocumentInput",
        "type": "object"
      },
      "RuntimeAgentRunRequest": {
        "properties": {
          "query": {
            "minLength": 1,
            "title": "Query",
            "type": "string"
          }
        },
        "required": [
          "query"
        ],
        "title": "RuntimeAgentRunRequest",
        "type": "object"
      },
      "RuntimeAgentRunResponse": {
        "properties": {
          "main_question": {
            "default": "",
            "title": "Main Question",
            "type": "string"
          },
          "output": {
            "title": "Output",
            "type": "string"
          },
          "sub_qa": {
            "items": {
              "$ref": "#/components/schemas/SubQuestionAnswer"
            },
            "title": "Sub Qa",
            "type": "array"
          }
        },
        "required": [
          "output"
        ],
        "title": "RuntimeAgentRunResponse",
        "type": "object"
      },
      "SubQuestionAnswer": {
        "properties": {
          "answerable": {
            "default": false,
            "title": "Answerable",
            "type": "boolean"
          },
          "expanded_query": {
            "default": "",
            "title": "Expanded Query",
            "type": "string"
          },
          "sub_agent_response": {
            "default": "",
            "title": "Sub Agent Response",
            "type": "string"
          },
          "sub_answer": {
            "title": "Sub Answer",
            "type": "string"
          },
          "sub_question": {
            "title": "Sub Question",
            "type": "string"
          },
          "tool_call_input": {
            "default": "",
            "title": "Tool Call Input",
            "type": "string"
          },
          "verification_reason": {
            "default": "",
            "title": "Verification Reason",
            "type": "string"
          }
        },
        "required": [
          "sub_question",
          "sub_answer"
        ],
        "title": "SubQuestionAnswer",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "WikiLoadInput": {
        "properties": {
          "source_id": {
            "minLength": 1,
            "title": "Source Id",
            "type": "string"
          }
        },
        "required": [
          "source_id"
        ],
        "title": "WikiLoadInput",
        "type": "object"
      },
      "WikiSourceOption": {
        "properties": {
          "already_loaded": {
            "title": "Already Loaded",
            "type": "boolean"
          },
          "article_query": {
            "title": "Article Query",
            "type": "string"
          },
          "label": {
            "title": "Label",
            "type": "string"
          },
          "source_id": {
            "title": "Source Id",
            "type": "string"
          }
        },
        "required": [
          "source_id",
          "label",
          "article_query",
          "already_loaded"
        ],
        "title": "WikiSourceOption",
        "type": "object"
      },
      "WikiSourcesResponse": {
        "properties": {
          "sources": {
            "items": {
              "$ref": "#/components/schemas/WikiSourceOption"
            },
            "title": "Sources",
            "type": "array"
          }
        },
        "required": [
          "sources"
        ],
        "title": "WikiSourcesResponse",
        "type": "object"
      },
      "WipeResponse": {
        "properties": {
          "message": {
            "title": "Message",
            "type": "string"
          },
          "status": {
            "const": "success",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status",
          "message"
        ],
        "title": "WipeResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "agent-search",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/agents/run": {
      "post": {
        "operationId": "runtime_agent_run_api_agents_run_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RuntimeAgentRunRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeAgentRunResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Runtime Agent Run",
        "tags": [
          "agents"
        ]
      }
    },
    "/api/health": {
      "get": {
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Api Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/api/internal-data/load": {
      "post": {
        "description": "Load internal data from deterministic wiki source.",
        "operationId": "load_data_api_internal_data_load_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InternalDataLoadRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InternalDataLoadResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Load Data",
        "tags": [
          "internal-data"
        ]
      }
    },
    "/api/internal-data/wiki-sources": {
      "get": {
        "description": "Return curated wiki source options with loaded state for the UI.",
        "operationId": "list_wiki_sources_api_internal_data_wiki_sources_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WikiSourcesResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Wiki Sources",
        "tags": [
          "internal-data"
        ]
      }
    },
    "/api/internal-data/wipe": {
      "post": {
        "description": "Wipe all internal documents and chunks.",
        "operationId": "wipe_data_api_internal_data_wipe_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WipeResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Wipe Data",
        "tags": [
          "internal-data"
        ]
      }
    }
  }
}
