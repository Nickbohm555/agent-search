flowchart TD
    A["POST /api/internal-data/load\nsrc/backend/routers/internal_data.py::load_data"] -->|"Trigger: load request\nData: InternalDataLoadRequest\nWhy: route delegates source-specific ingestion"| B["src/backend/services/internal_data_service.py::load_internal_data"]
    B -->|"Trigger: source_type=inline/wiki\nData: InternalDocumentInput[]\nWhy: normalize inputs before persistence"| C["src/backend/services/internal_data_service.py::_persist_documents"]
    C -->|"Data: chunk_text(content)\nWhy: split documents for retrieval granularity"| D["src/backend/utils/embeddings.py::chunk_text"]
